# Port for the HTTP MCP server
PORT=3200

# Wiki.js base URL (without /graphql)
WIKIJS_BASE_URL=http://localhost:3000

# Wiki.js API token used for health checks and legacy Claude Code auth
WIKIJS_TOKEN=your_wikijs_api_token_here

# Full-access admin token for provisioning new mcp- groups and API keys.
# Falls back to WIKIJS_TOKEN if not set.
WIKIJS_ADMIN_TOKEN=your_wikijs_admin_token_here

# Wiki.js locale used when building page URLs
WIKIJS_LOCALE=en

# =============================================================================
# OAuth 2.1 — MCP server as Authorization Server
# =============================================================================

# Public HTTPS base URL of this MCP server (no trailing slash).
# Used as the OAuth issuer and in well-known metadata.
OAUTH_ISSUER=https://mcp.knb.bulksource.com

# Credentials the Claude Desktop admin enters in the Connector settings UI
# (Connector → Client ID / Client Secret fields).
# Choose any stable opaque values; keep the secret safe.
OAUTH_CLIENT_ID=wikijs-mcp-client
OAUTH_CLIENT_SECRET=change-me-to-a-strong-random-secret

# Secret for signing MCP access tokens (HS256).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_JWT_SECRET=change-me-to-a-32-byte-hex-secret

# Access token lifetime in seconds (default 3600 = 1 hour)
OAUTH_ACCESS_TOKEN_TTL=3600

# Path to mcp-keys.json produced by scripts/provision-mcp-keys.sh.
# Mount this file into the container so the OAuth layer can read and update it.
MCP_KEYS_PATH=/app/mcp-keys.json

# Name of the Wiki.js group whose permissions are copied for auto-provisioned users
WIKIJS_TEMPLATE_GROUP=editors

# =============================================================================
# Google identity provider
# =============================================================================
# Create an OAuth 2.0 Web Application client in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Add this as an authorized redirect URI:
#   https://mcp.knb.bulksource.com/oauth/callback/google

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://mcp.knb.bulksource.com/oauth/callback/google

# =============================================================================
# Audit logging
# =============================================================================
AUDIT_LOG_PATH=/app/logs/audit.log
